# ─────────────────────────────────────────────────────────
# gitrails — environment variables
# NEVER commit .env — it is in .gitignore
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────

# Groq API key — get free at https://console.groq.com (no credit card)
# Free tier: 6000 TPM — sufficient for demo scans and real PR reviews
GROQ_API_KEY=your-groq-api-key-here

# ── Required ──────────────────────────────────────────────

# GitHub PAT — scopes: repo, pull_requests
GITHUB_TOKEN=your-github-pat-here

# ── Model ─────────────────────────────────────────────────

# No model is hardcoded anywhere — change here to switch globally.
# All agent yamls, demo-scan.js, and pr-scan.js read from env vars only.
GITRAILS_MODEL=groq:llama-3.3-70b-versatile
GITRAILS_FALLBACK_MODEL=groq:llama-3.1-8b-instant

# Production model routing (pr-scan.js)
# Heavy — used by sentinel, scribe, mirror (analysis + writing quality)
# Light — used by reviewer (simple weighted formula scoring)
GITRAILS_MODEL_HEAVY=groq:llama-3.3-70b-versatile
GITRAILS_MODEL_LIGHT=groq:llama-3.1-8b-instant
#
# To switch provider (e.g. OpenAI-compatible):
#   GITRAILS_MODEL_HEAVY=openai:gpt-4o
#   GITRAILS_MODEL_LIGHT=openai:gpt-4o-mini

GITRAILS_MAX_TURNS=50
GITRAILS_TIMEOUT=120

# ── Guardrails ────────────────────────────────────────────

GITRAILS_RISK_THRESHOLD=0.3
GITRAILS_AUDIT_RETENTION_DAYS=90

# ── Vector + Graph Retrieval ──────────────────────────────

GITRAILS_VECTOR_INDEX_PATH=./knowledge/vector-index
GITRAILS_GRAPH_PATH=./knowledge/graph.json
GITRAILS_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
GITRAILS_CHUNK_SIZE=512
GITRAILS_CHUNK_OVERLAP=64
GITRAILS_TOP_K=5
